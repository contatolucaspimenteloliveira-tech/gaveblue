<!doctype html>
<html lang="pt-BR" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WePeople - Sistema de Departamento Pessoal</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Plus Jakarta Sans', sans-serif; }
    .fade-in { animation: fadeIn 0.3s ease-out; }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .slide-in { animation: slideIn 0.4s ease-out; }
    @keyframes slideIn {
      from { opacity: 0; transform: translateX(-20px); }
      to { opacity: 1; transform: translateX(0); }
    }
    .pulse-dot {
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #1e293b; }
    ::-webkit-scrollbar-thumb { background: #475569; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #64748b; }
  </style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body class="h-full bg-slate-900 text-slate-100 overflow-hidden">
  <div id="app" class="h-full w-full flex"><!-- Sidebar -->
   <aside class="w-64 bg-slate-800 border-r border-slate-700 flex flex-col flex-shrink-0">
    <div class="p-6 border-b border-slate-700">
     <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-xl flex items-center justify-center">
       <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
       </svg>
      </div>
      <div>
       <h1 id="sidebar-company" class="font-bold text-lg text-white">WePeople</h1>
       <p class="text-xs text-slate-400">Departamento Pessoal</p>
      </div>
     </div>
    </div>
    <nav class="flex-1 p-4 space-y-2"><button onclick="setView('dashboard')" id="nav-dashboard" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all bg-emerald-500/20 text-emerald-400">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
      </svg><span class="font-medium">Dashboard</span> </button> <button onclick="setView('employees')" id="nav-employees" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all text-slate-400 hover:bg-slate-700/50 hover:text-white">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg><span class="font-medium">Colaboradores</span> </button> <button onclick="setView('departments')" id="nav-departments" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all text-slate-400 hover:bg-slate-700/50 hover:text-white">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
      </svg><span class="font-medium">Departamentos</span> </button> <button onclick="setView('reports')" id="nav-reports" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all text-slate-400 hover:bg-slate-700/50 hover:text-white">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg><span class="font-medium">Relatórios</span> </button>
    </nav>
    <div class="p-4 border-t border-slate-700">
     <div class="bg-gradient-to-r from-emerald-500/10 to-teal-500/10 rounded-xl p-4 border border-emerald-500/20">
      <div class="flex items-center gap-2 mb-2">
       <div class="w-2 h-2 bg-emerald-400 rounded-full pulse-dot"></div><span class="text-xs text-emerald-400 font-medium">Sistema Ativo</span>
      </div>
      <p class="text-xs text-slate-400">Dados sincronizados</p>
     </div>
    </div>
   </aside><!-- Main Content -->
   <main class="flex-1 flex flex-col overflow-hidden"><!-- Header -->
    <header class="bg-slate-800/50 backdrop-blur-sm border-b border-slate-700 px-8 py-4 flex items-center justify-between flex-shrink-0">
     <div>
      <h2 id="page-title" class="text-xl font-semibold text-white">Dashboard</h2>
      <p id="welcome-text" class="text-sm text-slate-400">Bem-vindo ao seu painel de gestão de pessoas</p>
     </div>
     <div class="flex items-center gap-4"><button onclick="openModal('add')" class="flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white px-5 py-2.5 rounded-xl font-medium transition-all shadow-lg shadow-emerald-500/25">
       <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
       </svg> Novo Colaborador </button>
     </div>
    </header><!-- Content Area -->
    <div class="flex-1 overflow-auto p-8"><!-- Dashboard View -->
     <div id="view-dashboard" class="view-content"><!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
       <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 slide-in">
        <div class="flex items-center justify-between mb-4">
         <div class="w-12 h-12 bg-emerald-500/20 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
         </div><span class="text-xs text-emerald-400 bg-emerald-500/20 px-2 py-1 rounded-lg">Total</span>
        </div>
        <h3 id="stat-total" class="text-3xl font-bold text-white mb-1">0</h3>
        <p class="text-sm text-slate-400">Colaboradores</p>
       </div>
       <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 slide-in" style="animation-delay: 0.1s">
        <div class="flex items-center justify-between mb-4">
         <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
         </div><span class="text-xs text-blue-400 bg-blue-500/20 px-2 py-1 rounded-lg">Ativos</span>
        </div>
        <h3 id="stat-active" class="text-3xl font-bold text-white mb-1">0</h3>
        <p class="text-sm text-slate-400">Em atividade</p>
       </div>
       <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 slide-in" style="animation-delay: 0.2s">
        <div class="flex items-center justify-between mb-4">
         <div class="w-12 h-12 bg-amber-500/20 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
         </div><span class="text-xs text-amber-400 bg-amber-500/20 px-2 py-1 rounded-lg">Férias</span>
        </div>
        <h3 id="stat-vacation" class="text-3xl font-bold text-white mb-1">0</h3>
        <p class="text-sm text-slate-400">De férias</p>
       </div>
       <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700 slide-in" style="animation-delay: 0.3s">
        <div class="flex items-center justify-between mb-4">
         <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
         </div><span class="text-xs text-purple-400 bg-purple-500/20 px-2 py-1 rounded-lg">Setores</span>
        </div>
        <h3 id="stat-departments" class="text-3xl font-bold text-white mb-1">0</h3>
        <p class="text-sm text-slate-400">Departamentos</p>
       </div>
      </div><!-- Recent Employees -->
      <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden">
       <div class="px-6 py-4 border-b border-slate-700 flex items-center justify-between">
        <h3 class="font-semibold text-white">Colaboradores Recentes</h3><button onclick="setView('employees')" class="text-sm text-emerald-400 hover:text-emerald-300 transition-colors">Ver todos →</button>
       </div>
       <div id="recent-employees" class="divide-y divide-slate-700">
        <div class="px-6 py-12 text-center text-slate-500">
         <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
         </svg>
         <p>Nenhum colaborador cadastrado</p>
         <p class="text-sm text-slate-600 mt-1">Clique em "Novo Colaborador" para começar</p>
        </div>
       </div>
      </div>
     </div><!-- Employees View -->
     <div id="view-employees" class="view-content hidden">
      <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden">
       <div class="px-6 py-4 border-b border-slate-700 flex items-center justify-between">
        <div class="flex items-center gap-4">
         <h3 class="font-semibold text-white">Lista de Colaboradores</h3>
         <div class="relative"><input type="text" id="search-input" placeholder="Buscar colaborador..." oninput="filterEmployees()" class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 pl-10 text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent w-64">
          <svg class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
         </div>
        </div><select id="filter-status" onchange="filterEmployees()" class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-emerald-500"> <option value="">Todos os status</option> <option value="Ativo">Ativos</option> <option value="Férias">Férias</option> <option value="Afastado">Afastados</option> <option value="Desligado">Desligados</option> </select>
       </div>
       <div id="employees-list" class="divide-y divide-slate-700">
        <div class="px-6 py-12 text-center text-slate-500">
         <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
         </svg>
         <p>Nenhum colaborador encontrado</p>
        </div>
       </div>
      </div>
     </div><!-- Departments View -->
     <div id="view-departments" class="view-content hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="departments-grid">
       <div class="col-span-full text-center py-12 text-slate-500">
        <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <p>Nenhum departamento com colaboradores</p>
        <p class="text-sm text-slate-600 mt-1">Adicione colaboradores para ver os departamentos</p>
       </div>
      </div>
     </div><!-- Reports View -->
     <div id="view-reports" class="view-content hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
       <div class="bg-slate-800 rounded-2xl border border-slate-700 p-6">
        <h3 class="font-semibold text-white mb-6">Distribuição por Status</h3>
        <div id="status-chart" class="space-y-4">
         <p class="text-slate-500 text-center py-8">Adicione colaboradores para ver o relatório</p>
        </div>
       </div>
       <div class="bg-slate-800 rounded-2xl border border-slate-700 p-6">
        <h3 class="font-semibold text-white mb-6">Colaboradores por Departamento</h3>
        <div id="dept-chart" class="space-y-4">
         <p class="text-slate-500 text-center py-8">Adicione colaboradores para ver o relatório</p>
        </div>
       </div>
       <div class="bg-slate-800 rounded-2xl border border-slate-700 p-6 lg:col-span-2">
        <h3 class="font-semibold text-white mb-6">Resumo da Folha de Pagamento</h3>
        <div id="payroll-summary" class="grid grid-cols-1 md:grid-cols-3 gap-6">
         <div class="bg-slate-700/50 rounded-xl p-4 text-center">
          <p class="text-sm text-slate-400 mb-1">Total da Folha</p>
          <p id="total-payroll" class="text-2xl font-bold text-emerald-400">R$ 0,00</p>
         </div>
         <div class="bg-slate-700/50 rounded-xl p-4 text-center">
          <p class="text-sm text-slate-400 mb-1">Média Salarial</p>
          <p id="avg-salary" class="text-2xl font-bold text-blue-400">R$ 0,00</p>
         </div>
         <div class="bg-slate-700/50 rounded-xl p-4 text-center">
          <p class="text-sm text-slate-400 mb-1">Maior Salário</p>
          <p id="max-salary" class="text-2xl font-bold text-purple-400">R$ 0,00</p>
         </div>
        </div>
       </div>
      </div>
     </div>
    </div>
   </main>
  </div><!-- Modal -->
  <div id="modal-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center">
   <div class="bg-slate-800 rounded-2xl border border-slate-700 w-full max-w-lg mx-4 max-h-[90%] overflow-auto fade-in">
    <div class="px-6 py-4 border-b border-slate-700 flex items-center justify-between">
     <h3 id="modal-title" class="font-semibold text-white text-lg">Novo Colaborador</h3><button onclick="closeModal()" class="text-slate-400 hover:text-white transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg></button>
    </div>
    <form id="employee-form" class="p-6 space-y-4"><input type="hidden" id="edit-id" value="">
     <div><label class="block text-sm font-medium text-slate-300 mb-2">Nome Completo *</label> <input type="text" id="input-name" required class="w-full bg-slate-700 border border-slate-600 rounded-xl px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="Digite o nome completo">
     </div>
     <div class="grid grid-cols-2 gap-4">
      <div><label class="block text-sm font-medium text-slate-300 mb-2">Cargo *</label> <input type="text" id="input-role" required class="w-full bg-slate-700 border border-slate-600 rounded-xl px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="Ex: Analista">
      </div>
      <div><label class="block text-sm font-medium text-slate-300 mb-2">Departamento *</label> <select id="input-department" required class="w-full bg-slate-700 border border-slate-600 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"> <option value="">Selecione...</option> <option value="Administrativo">Administrativo</option> <option value="Comercial">Comercial</option> <option value="Financeiro">Financeiro</option> <option value="Marketing">Marketing</option> <option value="Operações">Operações</option> <option value="RH">RH</option> <option value="TI">TI</option> </select>
      </div>
     </div>
     <div class="grid grid-cols-2 gap-4">
      <div><label class="block text-sm font-medium text-slate-300 mb-2">E-mail *</label> <input type="email" id="input-email" required class="w-full bg-slate-700 border border-slate-600 rounded-xl px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="email@empresa.com">
      </div>
      <div><label class="block text-sm font-medium text-slate-300 mb-2">Telefone</label> <input type="tel" id="input-phone" class="w-full bg-slate-700 border border-slate-600 rounded-xl px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="(00) 00000-0000">
      </div>
     </div>
     <div class="grid grid-cols-2 gap-4">
      <div><label class="block text-sm font-medium text-slate-300 mb-2">Data de Admissão *</label> <input type="date" id="input-hire-date" required class="w-full bg-slate-700 border border-slate-600 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent">
      </div>
      <div><label class="block text-sm font-medium text-slate-300 mb-2">Salário (R$) *</label> <input type="number" id="input-salary" required min="0" step="0.01" class="w-full bg-slate-700 border border-slate-600 rounded-xl px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="0,00">
      </div>
     </div>
     <div><label class="block text-sm font-medium text-slate-300 mb-2">Status</label> <select id="input-status" class="w-full bg-slate-700 border border-slate-600 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"> <option value="Ativo">Ativo</option> <option value="Férias">Férias</option> <option value="Afastado">Afastado</option> <option value="Desligado">Desligado</option> </select>
     </div>
     <div id="form-error" class="hidden bg-red-500/20 border border-red-500/30 text-red-400 px-4 py-3 rounded-xl text-sm"></div>
     <div class="flex gap-3 pt-4"><button type="button" onclick="closeModal()" class="flex-1 bg-slate-700 hover:bg-slate-600 text-white px-6 py-3 rounded-xl font-medium transition-colors"> Cancelar </button> <button type="submit" id="submit-btn" class="flex-1 bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white px-6 py-3 rounded-xl font-medium transition-all shadow-lg shadow-emerald-500/25"> Salvar </button>
     </div>
    </form>
   </div>
  </div><!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center">
   <div class="bg-slate-800 rounded-2xl border border-slate-700 w-full max-w-md mx-4 fade-in">
    <div class="p-6 text-center">
     <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
     </div>
     <h3 class="text-xl font-semibold text-white mb-2">Confirmar Exclusão</h3>
     <p class="text-slate-400 mb-6">Tem certeza que deseja excluir este colaborador? Esta ação não pode ser desfeita.</p>
     <div class="flex gap-3"><button onclick="closeDeleteModal()" class="flex-1 bg-slate-700 hover:bg-slate-600 text-white px-6 py-3 rounded-xl font-medium transition-colors"> Cancelar </button> <button onclick="confirmDelete()" id="confirm-delete-btn" class="flex-1 bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-xl font-medium transition-colors"> Excluir </button>
     </div>
    </div>
   </div>
  </div><!-- Toast -->
  <div id="toast" class="fixed bottom-6 right-6 bg-slate-800 border border-slate-700 rounded-xl px-6 py-4 shadow-xl transform translate-y-20 opacity-0 transition-all duration-300 z-50">
   <div class="flex items-center gap-3">
    <div id="toast-icon" class="w-8 h-8 bg-emerald-500/20 rounded-full flex items-center justify-center">
     <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
     </svg>
    </div>
    <p id="toast-message" class="text-white font-medium">Operação realizada com sucesso!</p>
   </div>
  </div>
  <script>
    // State
    let employees = [];
    let currentView = 'dashboard';
    let deleteTarget = null;
    let recordCount = 0;

    // Default config
    const defaultConfig = {
      company_name: 'WePeople',
      welcome_message: 'Bem-vindo ao seu painel de gestão de pessoas',
      background_color: '#0f172a',
      surface_color: '#1e293b',
      text_color: '#f1f5f9',
      primary_color: '#10b981',
      secondary_color: '#14b8a6',
      font_family: 'Plus Jakarta Sans',
      font_size: 16
    };

    // Initialize Element SDK
    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange: async (config) => {
          const companyName = config.company_name || defaultConfig.company_name;
          const welcomeMessage = config.welcome_message || defaultConfig.welcome_message;
          const bgColor = config.background_color || defaultConfig.background_color;
          const surfaceColor = config.surface_color || defaultConfig.surface_color;
          const textColor = config.text_color || defaultConfig.text_color;
          const primaryColor = config.primary_color || defaultConfig.primary_color;
          const secondaryColor = config.secondary_color || defaultConfig.secondary_color;
          const fontFamily = config.font_family || defaultConfig.font_family;
          const fontSize = config.font_size || defaultConfig.font_size;

          // Apply colors
          document.body.style.backgroundColor = bgColor;
          document.querySelectorAll('.bg-slate-800').forEach(el => el.style.backgroundColor = surfaceColor);
          document.body.style.color = textColor;
          
          // Apply text
          document.getElementById('sidebar-company').textContent = companyName;
          document.getElementById('welcome-text').textContent = welcomeMessage;
          
          // Apply font
          document.body.style.fontFamily = `${fontFamily}, sans-serif`;
          document.body.style.fontSize = `${fontSize}px`;
        },
        mapToCapabilities: (config) => ({
          recolorables: [
            {
              get: () => config.background_color || defaultConfig.background_color,
              set: (v) => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); }
            },
            {
              get: () => config.surface_color || defaultConfig.surface_color,
              set: (v) => { config.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); }
            },
            {
              get: () => config.text_color || defaultConfig.text_color,
              set: (v) => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); }
            },
            {
              get: () => config.primary_color || defaultConfig.primary_color,
              set: (v) => { config.primary_color = v; window.elementSdk.setConfig({ primary_color: v }); }
            },
            {
              get: () => config.secondary_color || defaultConfig.secondary_color,
              set: (v) => { config.secondary_color = v; window.elementSdk.setConfig({ secondary_color: v }); }
            }
          ],
          borderables: [],
          fontEditable: {
            get: () => config.font_family || defaultConfig.font_family,
            set: (v) => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); }
          },
          fontSizeable: {
            get: () => config.font_size || defaultConfig.font_size,
            set: (v) => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); }
          }
        }),
        mapToEditPanelValues: (config) => new Map([
          ['company_name', config.company_name || defaultConfig.company_name],
          ['welcome_message', config.welcome_message || defaultConfig.welcome_message]
        ])
      });
    }

    // Initialize Data SDK
    const dataHandler = {
      onDataChanged(data) {
        employees = data.filter(d => d.type === 'employee');
        recordCount = data.length;
        updateUI();
      }
    };

    async function initDataSDK() {
      if (window.dataSdk) {
        const result = await window.dataSdk.init(dataHandler);
        if (!result.isOk) {
          console.error('Failed to initialize Data SDK');
        }
      }
    }

    initDataSDK();

    // View Management
    function setView(view) {
      currentView = view;
      
      // Update navigation
      document.querySelectorAll('.nav-btn').forEach(btn => {
        btn.classList.remove('bg-emerald-500/20', 'text-emerald-400');
        btn.classList.add('text-slate-400', 'hover:bg-slate-700/50', 'hover:text-white');
      });
      
      const activeNav = document.getElementById(`nav-${view}`);
      if (activeNav) {
        activeNav.classList.remove('text-slate-400', 'hover:bg-slate-700/50', 'hover:text-white');
        activeNav.classList.add('bg-emerald-500/20', 'text-emerald-400');
      }
      
      // Update page title
      const titles = {
        dashboard: 'Dashboard',
        employees: 'Colaboradores',
        departments: 'Departamentos',
        reports: 'Relatórios'
      };
      document.getElementById('page-title').textContent = titles[view] || 'Dashboard';
      
      // Show/hide views
      document.querySelectorAll('.view-content').forEach(v => v.classList.add('hidden'));
      document.getElementById(`view-${view}`).classList.remove('hidden');
    }

    // UI Updates
    function updateUI() {
      updateStats();
      updateRecentEmployees();
      updateEmployeesList();
      updateDepartments();
      updateReports();
    }

    function updateStats() {
      const total = employees.length;
      const active = employees.filter(e => e.status === 'Ativo').length;
      const vacation = employees.filter(e => e.status === 'Férias').length;
      const departments = [...new Set(employees.map(e => e.department))].length;
      
      document.getElementById('stat-total').textContent = total;
      document.getElementById('stat-active').textContent = active;
      document.getElementById('stat-vacation').textContent = vacation;
      document.getElementById('stat-departments').textContent = departments;
    }

    function updateRecentEmployees() {
      const container = document.getElementById('recent-employees');
      const recent = [...employees].sort((a, b) => new Date(b.created_at) - new Date(a.created_at)).slice(0, 5);
      
      if (recent.length === 0) {
        container.innerHTML = `
          <div class="px-6 py-12 text-center text-slate-500">
            <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <p>Nenhum colaborador cadastrado</p>
            <p class="text-sm text-slate-600 mt-1">Clique em "Novo Colaborador" para começar</p>
          </div>
        `;
        return;
      }
      
      container.innerHTML = recent.map(emp => `
        <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-700/30 transition-colors">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-full flex items-center justify-center text-white font-semibold">
              ${getInitials(emp.name)}
            </div>
            <div>
              <p class="font-medium text-white">${emp.name}</p>
              <p class="text-sm text-slate-400">${emp.role} • ${emp.department}</p>
            </div>
          </div>
          <span class="px-3 py-1 rounded-full text-xs font-medium ${getStatusClass(emp.status)}">${emp.status}</span>
        </div>
      `).join('');
    }

    function updateEmployeesList() {
      const container = document.getElementById('employees-list');
      const searchTerm = document.getElementById('search-input').value.toLowerCase();
      const statusFilter = document.getElementById('filter-status').value;
      
      let filtered = employees;
      
      if (searchTerm) {
        filtered = filtered.filter(e => 
          e.name.toLowerCase().includes(searchTerm) ||
          e.role.toLowerCase().includes(searchTerm) ||
          e.department.toLowerCase().includes(searchTerm) ||
          e.email.toLowerCase().includes(searchTerm)
        );
      }
      
      if (statusFilter) {
        filtered = filtered.filter(e => e.status === statusFilter);
      }
      
      if (filtered.length === 0) {
        container.innerHTML = `
          <div class="px-6 py-12 text-center text-slate-500">
            <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <p>Nenhum colaborador encontrado</p>
          </div>
        `;
        return;
      }
      
      container.innerHTML = filtered.map(emp => `
        <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-700/30 transition-colors" data-id="${emp.__backendId}">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-full flex items-center justify-center text-white font-semibold text-lg">
              ${getInitials(emp.name)}
            </div>
            <div>
              <p class="font-medium text-white">${emp.name}</p>
              <p class="text-sm text-slate-400">${emp.role} • ${emp.department}</p>
              <p class="text-xs text-slate-500 mt-1">${emp.email} ${emp.phone ? '• ' + emp.phone : ''}</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-right">
              <p class="font-medium text-white">${formatCurrency(emp.salary)}</p>
              <p class="text-xs text-slate-400">Admissão: ${formatDate(emp.hire_date)}</p>
            </div>
            <span class="px-3 py-1 rounded-full text-xs font-medium ${getStatusClass(emp.status)}">${emp.status}</span>
            <div class="flex gap-2">
              <button onclick="openModal('edit', '${emp.__backendId}')" class="p-2 text-slate-400 hover:text-white hover:bg-slate-700 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
              </button>
              <button onclick="openDeleteModal('${emp.__backendId}')" class="p-2 text-slate-400 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      `).join('');
    }

    function updateDepartments() {
      const container = document.getElementById('departments-grid');
      const deptGroups = {};
      
      employees.forEach(emp => {
        if (!deptGroups[emp.department]) {
          deptGroups[emp.department] = [];
        }
        deptGroups[emp.department].push(emp);
      });
      
      const departments = Object.entries(deptGroups);
      
      if (departments.length === 0) {
        container.innerHTML = `
          <div class="col-span-full text-center py-12 text-slate-500">
            <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            <p>Nenhum departamento com colaboradores</p>
            <p class="text-sm text-slate-600 mt-1">Adicione colaboradores para ver os departamentos</p>
          </div>
        `;
        return;
      }
      
      const colors = ['emerald', 'blue', 'purple', 'amber', 'pink', 'cyan', 'orange'];
      
      container.innerHTML = departments.map(([dept, emps], i) => {
        const color = colors[i % colors.length];
        const activeCount = emps.filter(e => e.status === 'Ativo').length;
        const totalSalary = emps.reduce((sum, e) => sum + (e.salary || 0), 0);
        
        return `
          <div class="bg-slate-800 rounded-2xl border border-slate-700 p-6 slide-in" style="animation-delay: ${i * 0.1}s">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 bg-${color}-500/20 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-${color}-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-white">${dept}</h4>
                <p class="text-sm text-slate-400">${emps.length} colaborador${emps.length > 1 ? 'es' : ''}</p>
              </div>
            </div>
            <div class="space-y-3">
              <div class="flex justify-between text-sm">
                <span class="text-slate-400">Ativos</span>
                <span class="text-white font-medium">${activeCount}</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-slate-400">Folha Mensal</span>
                <span class="text-${color}-400 font-medium">${formatCurrency(totalSalary)}</span>
              </div>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-700">
              <div class="flex -space-x-2">
                ${emps.slice(0, 4).map(e => `
                  <div class="w-8 h-8 bg-gradient-to-br from-${color}-400 to-${color}-500 rounded-full flex items-center justify-center text-white text-xs font-medium border-2 border-slate-800">
                    ${getInitials(e.name)}
                  </div>
                `).join('')}
                ${emps.length > 4 ? `<div class="w-8 h-8 bg-slate-700 rounded-full flex items-center justify-center text-white text-xs font-medium border-2 border-slate-800">+${emps.length - 4}</div>` : ''}
              </div>
            </div>
          </div>
        `;
      }).join('');
    }

    function updateReports() {
      // Status chart
      const statusContainer = document.getElementById('status-chart');
      const statusCounts = {
        'Ativo': employees.filter(e => e.status === 'Ativo').length,
        'Férias': employees.filter(e => e.status === 'Férias').length,
        'Afastado': employees.filter(e => e.status === 'Afastado').length,
        'Desligado': employees.filter(e => e.status === 'Desligado').length
      };
      
      const total = employees.length;
      
      if (total === 0) {
        statusContainer.innerHTML = '<p class="text-slate-500 text-center py-8">Adicione colaboradores para ver o relatório</p>';
      } else {
        const statusColors = {
          'Ativo': 'emerald',
          'Férias': 'amber',
          'Afastado': 'orange',
          'Desligado': 'red'
        };
        
        statusContainer.innerHTML = Object.entries(statusCounts).filter(([_, count]) => count > 0).map(([status, count]) => {
          const color = statusColors[status];
          const percentage = Math.round((count / total) * 100);
          return `
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-slate-300">${status}</span>
                <span class="text-${color}-400 font-medium">${count} (${percentage}%)</span>
              </div>
              <div class="h-3 bg-slate-700 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-${color}-500 to-${color}-400 rounded-full transition-all duration-500" style="width: ${percentage}%"></div>
              </div>
            </div>
          `;
        }).join('');
      }
      
      // Department chart
      const deptContainer = document.getElementById('dept-chart');
      const deptCounts = {};
      employees.forEach(e => {
        deptCounts[e.department] = (deptCounts[e.department] || 0) + 1;
      });
      
      if (Object.keys(deptCounts).length === 0) {
        deptContainer.innerHTML = '<p class="text-slate-500 text-center py-8">Adicione colaboradores para ver o relatório</p>';
      } else {
        const maxCount = Math.max(...Object.values(deptCounts));
        const colors = ['emerald', 'blue', 'purple', 'amber', 'pink', 'cyan'];
        
        deptContainer.innerHTML = Object.entries(deptCounts).sort((a, b) => b[1] - a[1]).map(([dept, count], i) => {
          const color = colors[i % colors.length];
          const percentage = Math.round((count / maxCount) * 100);
          return `
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-slate-300">${dept}</span>
                <span class="text-${color}-400 font-medium">${count}</span>
              </div>
              <div class="h-3 bg-slate-700 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-${color}-500 to-${color}-400 rounded-full transition-all duration-500" style="width: ${percentage}%"></div>
              </div>
            </div>
          `;
        }).join('');
      }
      
      // Payroll summary
      const salaries = employees.filter(e => e.status === 'Ativo').map(e => e.salary || 0);
      const totalPayroll = salaries.reduce((sum, s) => sum + s, 0);
      const avgSalary = salaries.length > 0 ? totalPayroll / salaries.length : 0;
      const maxSalary = salaries.length > 0 ? Math.max(...salaries) : 0;
      
      document.getElementById('total-payroll').textContent = formatCurrency(totalPayroll);
      document.getElementById('avg-salary').textContent = formatCurrency(avgSalary);
      document.getElementById('max-salary').textContent = formatCurrency(maxSalary);
    }

    function filterEmployees() {
      updateEmployeesList();
    }

    // Modal Management
    function openModal(mode, id = null) {
      const modal = document.getElementById('modal-overlay');
      const form = document.getElementById('employee-form');
      const title = document.getElementById('modal-title');
      
      form.reset();
      document.getElementById('form-error').classList.add('hidden');
      
      if (mode === 'edit' && id) {
        const emp = employees.find(e => e.__backendId === id);
        if (emp) {
          title.textContent = 'Editar Colaborador';
          document.getElementById('edit-id').value = id;
          document.getElementById('input-name').value = emp.name || '';
          document.getElementById('input-role').value = emp.role || '';
          document.getElementById('input-department').value = emp.department || '';
          document.getElementById('input-email').value = emp.email || '';
          document.getElementById('input-phone').value = emp.phone || '';
          document.getElementById('input-hire-date').value = emp.hire_date || '';
          document.getElementById('input-salary').value = emp.salary || '';
          document.getElementById('input-status').value = emp.status || 'Ativo';
        }
      } else {
        title.textContent = 'Novo Colaborador';
        document.getElementById('edit-id').value = '';
        document.getElementById('input-hire-date').value = new Date().toISOString().split('T')[0];
      }
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      const modal = document.getElementById('modal-overlay');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    function openDeleteModal(id) {
      deleteTarget = id;
      const modal = document.getElementById('delete-modal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeDeleteModal() {
      deleteTarget = null;
      const modal = document.getElementById('delete-modal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    async function confirmDelete() {
      if (!deleteTarget) return;
      
      const emp = employees.find(e => e.__backendId === deleteTarget);
      if (!emp) return;
      
      const btn = document.getElementById('confirm-delete-btn');
      btn.disabled = true;
      btn.textContent = 'Excluindo...';
      
      const result = await window.dataSdk.delete(emp);
      
      btn.disabled = false;
      btn.textContent = 'Excluir';
      
      if (result.isOk) {
        showToast('Colaborador excluído com sucesso!', 'success');
        closeDeleteModal();
      } else {
        showToast('Erro ao excluir colaborador', 'error');
      }
    }

    // Form submission
    document.getElementById('employee-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const editId = document.getElementById('edit-id').value;
      const isEdit = !!editId;
      
      // Check limit for new records
      if (!isEdit && recordCount >= 999) {
        document.getElementById('form-error').textContent = 'Limite máximo de 999 registros atingido. Por favor, exclua alguns registros primeiro.';
        document.getElementById('form-error').classList.remove('hidden');
        return;
      }
      
      const data = {
        type: 'employee',
        name: document.getElementById('input-name').value.trim(),
        role: document.getElementById('input-role').value.trim(),
        department: document.getElementById('input-department').value,
        email: document.getElementById('input-email').value.trim(),
        phone: document.getElementById('input-phone').value.trim(),
        hire_date: document.getElementById('input-hire-date').value,
        salary: parseFloat(document.getElementById('input-salary').value) || 0,
        status: document.getElementById('input-status').value,
        created_at: new Date().toISOString()
      };
      
      const btn = document.getElementById('submit-btn');
      btn.disabled = true;
      btn.textContent = 'Salvando...';
      
      let result;
      
      if (isEdit) {
        const emp = employees.find(e => e.__backendId === editId);
        if (emp) {
          result = await window.dataSdk.update({ ...emp, ...data });
        }
      } else {
        result = await window.dataSdk.create(data);
      }
      
      btn.disabled = false;
      btn.textContent = 'Salvar';
      
      if (result && result.isOk) {
        showToast(isEdit ? 'Colaborador atualizado com sucesso!' : 'Colaborador cadastrado com sucesso!', 'success');
